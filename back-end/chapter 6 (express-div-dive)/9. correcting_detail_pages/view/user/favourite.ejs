<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Wishlist</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    body {
      background-color: #f7f7f7;
    }
  </style>
</head>
<body>

  <!-- Navbar -->
  <div class="bg-white shadow-sm px-8 py-4 flex justify-between items-center">
    <h1 class="text-xl font-semibold">Wishlist</h1>
    <div class="text-gray-500">Saved homes ❤️</div>
  </div>

  <div class="max-w-6xl mx-auto mt-8 px-4">

    <% if (data.length === 0) { %>
      <div class="text-center mt-20 text-gray-500 text-lg">
        No saved homes yet 💔
      </div>
    <% } else { %>

      <!-- Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">

        <% data.forEach(item => { %>

          <!-- Card -->
          <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition duration-300">

            <!-- Image -->
            <div class="relative">
              <img 
                src="<%= item.property.image %>" 
                class="w-full h-56 object-cover"
              >

              <!-- Heart icon -->
              <button class="absolute top-3 right-3 bg-white p-2 rounded-full shadow hover:scale-110 transition">
                ❤️
              </button>
            </div>

            <!-- Content -->
            <div class="p-4">

              <div class="flex justify-between items-center">
                <h3 class="font-semibold text-lg">
                  <%= item.property.title %>
                </h3>

                <span class="text-sm font-medium">
                  ⭐ <%= item.property.rating %>
                </span>
              </div>

              <p class="text-gray-500 text-sm mt-1">
                <%= item.property.location %>
              </p>

              <p class="mt-3 font-semibold">
                ₹<%= item.property.pricePerNight %> 
                <span class="text-gray-500 text-sm">/ night</span>
              </p>

              <!-- Buttons -->
              <div class="mt-4 flex justify-between items-center">

                <button class="text-sm px-4 py-2 border rounded-lg hover:bg-gray-100">
                  View
                </button>

                <button class="text-sm px-4 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600">
                  Remove
                </button>

              </div>

            </div>
          </div>

        <% }) %>

      </div>

    <% } %>

  </div>

</body>
</html>