<!-- booking.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Bookings</title>
<link rel="stylesheet" href="/booking.css">
</head>
<body>

<!-- Navbar -->
<header class="navbar">
  <div class="logo">Trips</div>
  <div class="nav-right">Welcome Back 👋</div>
</header>

<!-- Hero -->
<section class="hero">
  <h1>Your Booked Stays</h1>
  <p>Manage your upcoming stays and discover beautiful homes.</p>
</section>

<!-- Booking Cards -->
<section class="main-container">

<% 
const validBookings = data.filter(item => item.homeName && item.photourl);
%>

<% if(validBookings.length === 0){ %>

<div class="empty-box">
  <h2>No bookings yet 🏡</h2>
  <p>Book your next trip now.</p>
</div>

<% } else { %>

<div class="booking-grid">

<% validBookings.forEach(booking => { %>

<div class="card">

  <div class="image-box">
    <img src="<%= booking.photourl %>" alt="home image">
    <span class="rating">⭐ <%= booking.rating %></span>
  </div>

  <div class="card-content">

    <h2><%= booking.homeName %></h2>

    <p class="location"><%= booking.Location %></p>

    <div class="bottom-row">
      <p class="price">₹<%= booking.pricePerNight %> <span>/night</span></p>

      <button>View</button>
    </div>

  </div>

</div>

<% }) %>

</div>

<% } %>

</section>

</body>
</html>